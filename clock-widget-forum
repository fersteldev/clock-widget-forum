<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
body{
  margin:0;
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background:#0b0d10;
  font-family:Inter,Arial,Helvetica,sans-serif;
}

.widget{
  width:250px;
  padding:18px;
  border-radius:16px;
  background:rgba(255,255,255,0.04);
  backdrop-filter:blur(10px);
  border:1px solid rgba(255,255,255,0.08);
  color:#eaeaea;
}

.header{
  text-align:center;
  margin-bottom:16px;
  cursor:pointer;
}

.clock{
  font-size:34px;
  font-weight:700;
  letter-spacing:1px;
}

.date{
  font-size:12px;
  opacity:0.6;
  margin-top:4px;
}

.section{
  margin-top:12px;
  overflow:hidden;
  max-height:500px;
  opacity:1;
  transition: all 0.35s ease;
}

.section.collapsed{
  max-height:0;
  opacity:0;
  margin-top:0;
}

.section-title{
  font-size:11px;
  text-transform:uppercase;
  letter-spacing:1px;
  opacity:0.5;
  margin-bottom:6px;
  text-align:center;
}

.tz{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:10px 12px;
  border-radius:10px;
  background:rgba(255,255,255,0.03);
  margin-bottom:6px;
  font-size:13px;
}

.tz i{
  margin-right:6px;
  opacity:0.7;
}

.tz span:last-child{
  font-weight:600;
}

.tz:hover{
  background:rgba(255,255,255,0.06);
}

.hint{
  font-size:10px;
  opacity:0.35;
  margin-top:6px;
}

.search{
  margin-top:10px;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.search input{
  width:100%;
  padding:8px 10px;
  border-radius:8px;
  border:none;
  outline:none;
  font-size:12px;
  background:rgba(255,255,255,0.06);
  color:#fff;
}

.result{
  overflow:hidden;
  max-height:0;
  opacity:0;
  transition:all 0.3s ease;
}

.result.show{
  max-height:60px;
  opacity:1;
}
</style>

<div class="widget">

  <div class="header" id="toggle">
    <div class="clock" id="clock">00:00:00</div>
    <div class="date" id="date">--</div>
    <div class="hint">click to toggle time zones</div>
  </div>

  <div class="section" id="section">

    <div class="section-title">Time zones</div>

    <div class="tz">
      <div><i class="fa-solid fa-location-dot"></i> Local</div>
      <span id="local"></span>
    </div>

    <div class="tz">
      <div><i class="fa-solid fa-globe"></i> UTC</div>
      <span id="utc"></span>
    </div>

    <div class="tz">
      <div><i class="fa-solid fa-flag-usa"></i> New York</div>
      <span id="ny"></span>
    </div>

    <div class="tz">
      <div><i class="fa-solid fa-torii-gate"></i> Tokyo</div>
      <span id="tokyo"></span>
    </div>

    <div class="search">
      <input id="search" placeholder="search city...">
      <div class="result" id="result">
        <div class="tz">
          <div id="resultName"></div>
          <span id="resultTime"></span>
        </div>
      </div>
    </div>

  </div>

</div>

<script>
let collapsed = localStorage.getItem("collapsed") === "1";

function apply(){
  document.getElementById("section")
    .classList.toggle("collapsed", collapsed);
}

document.getElementById("toggle").onclick = () => {
  collapsed = !collapsed;
  localStorage.setItem("collapsed", collapsed ? "1" : "0");
  apply();
};

apply();

const map = {
  // EUROPE
  poland: "Europe/Warsaw",
  warsaw: "Europe/Warsaw",
  germany: "Europe/Berlin",
  berlin: "Europe/Berlin",
  france: "Europe/Paris",
  paris: "Europe/Paris",
  spain: "Europe/Madrid",
  madrid: "Europe/Madrid",
  italy: "Europe/Rome",
  rome: "Europe/Rome",
  uk: "Europe/London",
  england: "Europe/London",
  london: "Europe/London",
  netherlands: "Europe/Amsterdam",
  amsterdam: "Europe/Amsterdam",
  sweden: "Europe/Stockholm",
  stockholm: "Europe/Stockholm",
  norway: "Europe/Oslo",
  oslo: "Europe/Oslo",
  finland: "Europe/Helsinki",
  helsinki: "Europe/Helsinki",
  switzerland: "Europe/Zurich",
  zurich: "Europe/Zurich",
  austria: "Europe/Vienna",
  vienna: "Europe/Vienna",
  greece: "Europe/Athens",
  athens: "Europe/Athens",
  turkey: "Europe/Istanbul",
  istanbul: "Europe/Istanbul",

  // NORTH AMERICA
  usa: "America/New_York",
  unitedstates: "America/New_York",
  newyork: "America/New_York",
  ny: "America/New_York",
  toronto: "America/Toronto",
  canada: "America/Toronto",
  mexico: "America/Mexico_City",
  mexicocity: "America/Mexico_City",
  losangeles: "America/Los_Angeles",
  la: "America/Los_Angeles",
  chicago: "America/Chicago",
  miami: "America/New_York",
  vancouver: "America/Vancouver",

  // SOUTH AMERICA
  brazil: "America/Sao_Paulo",
  brasil: "America/Sao_Paulo",
  saopaulo: "America/Sao_Paulo",
  rio: "America/Sao_Paulo",
  argentina: "America/Argentina/Buenos_Aires",
  buenosaires: "America/Argentina/Buenos_Aires",
  chile: "America/Santiago",
  santiago: "America/Santiago",
  colombia: "America/Bogota",
  bogota: "America/Bogota",
  peru: "America/Lima",
  lima: "America/Lima",

  // ASIA
  japan: "Asia/Tokyo",
  tokyo: "Asia/Tokyo",
  china: "Asia/Shanghai",
  beijing: "Asia/Shanghai",
  shanghai: "Asia/Shanghai",
  india: "Asia/Kolkata",
  mumbai: "Asia/Kolkata",
  delhi: "Asia/Kolkata",
  singapore: "Asia/Singapore",
  thailand: "Asia/Bangkok",
  bangkok: "Asia/Bangkok",
  korea: "Asia/Seoul",
  seoul: "Asia/Seoul",
  vietnam: "Asia/Ho_Chi_Minh",
  dubai: "Asia/Dubai",
  uae: "Asia/Dubai",
  israel: "Asia/Jerusalem",
  jerusalem: "Asia/Jerusalem",

  // AFRICA
  morocco: "Africa/Casablanca",
  casablanca: "Africa/Casablanca",
  egypt: "Africa/Cairo",
  cairo: "Africa/Cairo",
  southafrica: "Africa/Johannesburg",
  johannesburg: "Africa/Johannesburg",
  nigeria: "Africa/Lagos",
  lagos: "Africa/Lagos",
  kenya: "Africa/Nairobi",
  nairobi: "Africa/Nairobi",

  // OCEANIA
  australia: "Australia/Sydney",
  sydney: "Australia/Sydney",
  melbourne: "Australia/Melbourne",
  perth: "Australia/Perth",
  newzealand: "Pacific/Auckland",
  auckland: "Pacific/Auckland"
};

let currentTZ = null;
let currentName = "";

document.getElementById("search").oninput = e => {
  const val = e.target.value.toLowerCase().replace(/\s/g,'');

  if(map[val]){
    currentTZ = map[val];
    currentName = e.target.value;
    document.getElementById("resultName").innerText = currentName;
    document.getElementById("result").classList.add("show");
  }else{
    currentTZ = null;
    document.getElementById("result").classList.remove("show");
  }
};

function update(){
  const now = new Date();

  function format(tz){
    return now.toLocaleTimeString("pl-PL", {
      timeZone: tz,
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  document.getElementById("clock").innerText =
    now.toLocaleTimeString("pl-PL");

  document.getElementById("date").innerText =
    now.toLocaleDateString("pl-PL", {
      weekday:"long",
      day:"numeric",
      month:"long"
    });

  document.getElementById("local").innerText =
    format(Intl.DateTimeFormat().resolvedOptions().timeZone);

  document.getElementById("utc").innerText = format("UTC");
  document.getElementById("ny").innerText = format("America/New_York");
  document.getElementById("tokyo").innerText = format("Asia/Tokyo");

  if(currentTZ){
    document.getElementById("resultTime").innerText = format(currentTZ);
  }
}

update();
setInterval(update,1000);
</script>
